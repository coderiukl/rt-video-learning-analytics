pipeline {
    agent any

    environment {
        PROJECT_DIR = '/workspace'
    }

    stages {
        stage('Sync repo') {
            steps {
                sh '''
                    cd ${PROJECT_DIR}
                    git fetch origin main
                    git checkout main
                    git pull --ff-only origin main
                '''
            }
        }

        stage('Pull models') {
            steps {
                sh 'cd ${PROJECT_DIR} && dvc pull --allow-missing || true'
            }
        }

        stage('Build & Deploy') {
            steps {
                sh '''
                    cd ${PROJECT_DIR}
                    docker compose build backend frontend
                    docker compose up -d --no-deps backend frontend
                    docker compose ps
                '''
            }
        }

        stage('Healthcheck') {
            steps {
                sh 'sleep 5 && curl -fsS http://localhost:8000/health/ || true'
            }
        }
    }

    post {
        success { echo 'Deploy succeeded.' }
        failure { echo 'Deploy failed. Check Jenkins logs.' }
    }
}
