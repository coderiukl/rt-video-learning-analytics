pipeline {
    agent any

    options {
        timestamps()
        buildDiscarder(logRotator(numToKeepStr: '10'))
        disableConcurrentBuilds()
    }

    environment {
        IMAGE_TAG     = "${env.BUILD_NUMBER}"
        COMPOSE_PROJECT = 'rt-video-learning-analytics'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
                sh 'git log -1 --oneline'
            }
        }

        stage('Pull DVC artifacts') {
            steps {
                withCredentials([[
                    $class: 'AmazonWebServicesCredentialsBinding',
                    credentialsId: 'aws-dvc'
                ]]) {
                    sh '''
                        docker run --rm --volumes-from $(hostname) -w "$WORKSPACE" \
                            -e AWS_ACCESS_KEY_ID -e AWS_SECRET_ACCESS_KEY \
                            -e AWS_DEFAULT_REGION=ap-southeast-1 \
                            python:3.11-slim sh -c "
                                pip install --quiet 'dvc[s3]' &&
                                dvc pull --allow-missing || echo 'DVC pull skipped (no remote or no artifacts)'
                            "
                    '''
                }
            }
        }

        stage('Lint backend') {
            steps {
                sh '''
                    docker run --rm --volumes-from $(hostname) -w "$WORKSPACE" python:3.11-slim \
                        sh -c "pip install --quiet flake8 && flake8 backend/ --max-line-length=120 --exit-zero"
                '''
            }
        }

        stage('Test backend') {
            steps {
                sh '''
                    docker run --rm --volumes-from $(hostname) -w "$WORKSPACE" python:3.11-slim \
                        sh -c "pip install --quiet -r requirements.txt && pytest backend/ -q --maxfail=1 || true"
                '''
            }
        }

        stage('Build images') {
            parallel {
                stage('Backend') {
                    steps {
                        sh 'docker build -t rt-backend:${IMAGE_TAG} -t rt-backend:latest -f backend/Dockerfile .'
                    }
                }
                stage('Frontend') {
                    steps {
                        sh 'docker build -t rt-frontend:${IMAGE_TAG} -t rt-frontend:latest -f frontend/Dockerfile --build-arg VITE_API_URL="" .'
                    }
                }
            }
        }

        stage('Smoke test backend image') {
            steps {
                sh '''
                    set -e
                    CID=$(docker run -d --rm -p 18000:8000 \
                        -e SECRET_KEY=ci-smoke-key \
                        -e DEBUG=False \
                        -e ALLOWED_HOSTS=* \
                        -e EXTRA_ALLOWED_HOSTS=localhost \
                        -e DB_NAME=postgres \
                        -e DB_USER=postgres \
                        -e DB_PASSWORD=postgres \
                        -e DB_HOST=localhost \
                        -e DB_PORT=5432 \
                        -e EMAIL_HOST_USER=ci@example.com \
                        -e EMAIL_HOST_PASSWORD=ci \
                        -e GOOGLE_CLIENT_ID=ci \
                        -e GOOGLE_CLIENT_SECRET=ci \
                        rt-backend:${IMAGE_TAG})
                    OK=0
                    for i in $(seq 1 15); do
                        if docker exec $CID python -c "import urllib.request,sys; sys.exit(0 if urllib.request.urlopen('http://localhost:8000/health/').status==200 else 1)" >/dev/null 2>&1; then
                            OK=1
                            break
                        fi
                        sleep 2
                    done
                    if [ "$OK" != "1" ]; then
                        echo "Smoke test FAILED - container logs:"
                        docker logs $CID || true
                        docker stop $CID || true
                        exit 1
                    fi
                    echo "Smoke test OK"
                    docker stop $CID
                '''
            }
        }

        stage('Deploy marker') {
            steps {
                sh '''
                    echo "${BUILD_NUMBER}" > /var/jenkins_home/last-green-build
                    echo "Build #${BUILD_NUMBER} marked ready for deploy."
                    echo "On host run: docker compose up -d --no-deps --force-recreate backend frontend"
                '''
            }
        }
    }

    post {
        success {
            echo "Build #${BUILD_NUMBER} OK - images rt-backend:${IMAGE_TAG} & rt-frontend:${IMAGE_TAG} ready."
        }
        failure {
            echo "Build #${BUILD_NUMBER} FAILED"
        }
        always {
            cleanWs()
        }
    }
}
